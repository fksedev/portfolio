{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Prepare portfolio debug",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/prepare-debug.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      }
    },
    {
      "label": "Preview in Chrome",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/preview.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      }
    },
    {
      "label": "Start local server (port 8080)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/prepare-debug.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      }
    },
    {
      "label": "Stop local server (port 8080)",
      "type": "shell",
      "command": "lsof -ti :8080 | xargs kill -9 2>/dev/null; echo 'Stopped any process on port 8080'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
